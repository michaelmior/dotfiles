{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/osascript
use AppleScript version "2.4"
use framework "AppKit"
use scripting additions

property NSScreen : a reference to current application's NSScreen

set ghosttyAppName to "Ghostty"
set onePasswordAppName to "1Password"
set timeoutSeconds to 5
set pollInterval to 0.05

set ghosttyBounds to my frontWindowBounds(ghosttyAppName)
if ghosttyBounds is missing value then error "Could not find a front window for " & ghosttyAppName

set targetScreen to my screenForWindowBounds(ghosttyBounds)
if targetScreen is missing value then error "Could not determine which display " & ghosttyAppName & " is on"

set winRef to my waitForFrontWindow(onePasswordAppName, timeoutSeconds, pollInterval)
if winRef is missing value then error "No 1Password window appeared within " & timeoutSeconds & " seconds."

my moveWindowToScreen(onePasswordAppName, winRef, targetScreen)
return "Moved 1Password to the same display as Ghostty and centered it."

on frontWindowBounds(appName)
	tell application "System Events"
		if not (exists process appName) then return missing value
		
		tell process appName
			if (count of windows) = 0 then return missing value
			
			set win to front window
			set {xPos, yPos} to position of win
			set {w, h} to size of win
			return {x:xPos, y:yPos, width:w, height:h}
		end tell
	end tell
end frontWindowBounds

on waitForFrontWindow(appName, timeoutSeconds, pollInterval)
	set deadline to (current date) + timeoutSeconds
	
	repeat while (current date) < deadline
		tell application "System Events"
			if exists process appName then
				tell process appName
					if (count of windows) > 0 then
						try
							set win to front window
							set _pos to position of win
							set _size to size of win
							return win
						end try
					end if
				end tell
			end if
		end tell
		delay pollInterval
	end repeat
	
	return missing value
end waitForFrontWindow

on screenForWindowBounds(winBounds)
	set midX to (x of winBounds) + ((width of winBounds) / 2)
	set midY_AX to (y of winBounds) + ((height of winBounds) / 2)
	
	set screens to NSScreen's screens()
	if (count of screens) = 0 then return missing value
	
	set maxY to my maxScreenY(screens)
	set midY_Cocoa to maxY - midY_AX
	
	repeat with aScreen in screens
		set frameRect to (aScreen's frame()) as list
		set frameOrigin to item 1 of frameRect
		set frameSize to item 2 of frameRect
		
		set sx to item 1 of frameOrigin as real
		set sy to item 2 of frameOrigin as real
		set sw to item 1 of frameSize as real
		set sh to item 2 of frameSize as real
		
		if midX ≥ sx and midX < (sx + sw) and midY_Cocoa ≥ sy and midY_Cocoa < (sy + sh) then
			return aScreen
		end if
	end repeat
	
	return missing value
end screenForWindowBounds

on moveWindowToScreen(appName, winRef, targetScreen)
	set screenRect to (targetScreen's visibleFrame()) as list
	set screenOrigin to item 1 of screenRect
	set screenSize to item 2 of screenRect
	
	set sx to item 1 of screenOrigin as real
	set sy to item 2 of screenOrigin as real
	set sw to item 1 of screenSize as real
	set sh to item 2 of screenSize as real
	
	tell application "System Events"
		if not (exists process appName) then error appName & " is not running."
		
		tell process appName
			set {ww, wh} to size of winRef
			
			set targetX to sx + ((sw - ww) / 2)
			set targetY_Cocoa to sy + ((sh - wh) / 2)
			
			set screens to NSScreen's screens()
			set maxY to my maxScreenY(screens)
			set targetY to maxY - targetY_Cocoa - wh
			
			set position of winRef to {targetX, targetY}
		end tell
	end tell
end moveWindowToScreen

on maxScreenY(screenList)
	set maxY to -1000000
	
	repeat with aScreen in screenList
		set frameRect to (aScreen's frame()) as list
		set frameOrigin to item 1 of frameRect
		set frameSize to item 2 of frameRect
		
		set sy to item 2 of frameOrigin as real
		set sh to item 2 of frameSize as real
		
		set candidate to sy + sh
		if candidate > maxY then set maxY to candidate
	end repeat
	
	return maxY
end maxScreenY
{{- end -}}
